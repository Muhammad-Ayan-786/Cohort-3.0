								{
									"type": "text",
									"text": "Navbar is shown on all the pages, only Home, About & Services are changing."
								}
							]
						},
						{
							"type": "paragraph",
							"attrs": {
								"dir": "auto"
							},
							"content": [
								{
									"type": "text",
									"text": "E.g. Navbar is shown on all the pages. User clicks About Navlink inside Navbar. Outlet renders the About page. As all the page are the children of MainLayout, and Outlet renders the children according to the route. "
								}
							]
						},
						{
							"type": "paragraph",
							"attrs": {
